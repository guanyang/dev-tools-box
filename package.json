{
  "name": "dev-tools-box",
  "version": "1.3.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "extension:dev": "EXTENSION_BROWSER=chrome vite --config vite.extension.config.ts",
    "extension:build": "node scripts/build-extensions.mjs",
    "extension:size": "node scripts/check-extension-size.mjs",
    "extension:package": "npm run extension:build && npm run extension:size && node scripts/package-extensions.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "test:csp": "node --disallow-code-generation-from-strings --experimental-strip-types --test tests/v1.2-data-tools.test.mjs",
    "test:ui": "vitest run",
    "test": "npm run typecheck && npm run test:csp && npm run test:ui && npm run build && npm run extension:package && node --experimental-strip-types --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern dist-extension"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@codemirror/lang-json": "^6.0.2",
    "@noble/hashes": "^2.2.0",
    "@uiw/react-codemirror": "^4.25.11",
    "fast-xml-parser": "^5.10.1",
    "jsonpath-plus": "^10.4.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "papaparse": "^5.5.4",
    "prism-react-renderer": "^2.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "smol-toml": "^1.7.0",
    "sql-formatter": "^15.8.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
